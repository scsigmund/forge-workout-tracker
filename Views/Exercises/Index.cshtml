@model IEnumerable<forge_workout_tracker.Models.Exercise>

<h1>Exercises</h1>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Muscle Group</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var exercise in Model)
        {
            <tr>
                <td>@exercise.Name</td>
                <td>@exercise.MuscleGroup</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@exercise.Id">Edit</a>
                    <form asp-action="Delete" asp-route-id="@exercise.Id" method="post" style="display:inline">
                        <button type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>